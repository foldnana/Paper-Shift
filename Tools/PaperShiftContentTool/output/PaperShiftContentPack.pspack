# ===========================================
# 后半生规则 (@lifeRule) — 重新设计
# ===========================================
# 核心原则：低薪跨代惩罚更重，高薪有隐性代价，简历风险跨代传播

@lifeRule physical_wear
name: 体力劳动的身体代价
priority: 135
condition: JobHasTag physical
condition: RandomChance chance=0.45
effect: AddHealth int=-12
effect: AddHeirStress int=5
effect: AddMilestone text="旧伤" secondary="体力透支"
effect: AddStoryFragment text="身体的账迟早要还，后来总是某个关节先出问题。"
@end

@lifeRule outdoor_weather
name: 风里来雨里去
priority: 140
condition: JobHasTag outdoor
condition: RandomChance chance=0.35
effect: AddHealth int=-8
effect: AddLifePressure int=8
effect: AddMilestone text="风吹日晒" secondary="身体磨耗"
effect: AddStoryFragment text="常年在户外，皮肤和骨头都记住了那些天气。"
@end

@lifeRule night_shift_health
name: 夜班的身体账
priority: 142
condition: JobHasTag night_shift
condition: RandomChance chance=0.4
effect: AddHealth int=-10
effect: AddLifePressure int=10
effect: AddHeirStress int=7
effect: AddMilestone text="失眠" secondary="昼夜紊乱"
effect: AddStoryFragment text="倒班的日子结束后，睡眠再也没有完全恢复正常。"
@end

@lifeRule strict_rules_habit
name: 规则严格养成的习惯
priority: 145
condition: JobHasTag strict_rules
effect: AddHeirStat key=maturity int=3
effect: AddParentCare int=3
effect: AddHeirStress int=3
effect: AddMilestone text="守规矩" secondary="秩序感"
effect: AddStoryFragment text="在严格的环境待久了，连对孩子的要求也变多了。"
@end

@lifeRule customer_contact_social
name: 客户接触带来的社交能力
priority: 150
condition: JobHasTag customer_contact
condition: RandomChance chance=0.45
effect: AddHeirStat key=communication int=2
effect: AddFamilyReputation int=4
effect: AddChildChance int=3
effect: AddStoryFragment text="天天和人打交道，后来在孩子面前也能说会道。"
@end

@lifeRule low_income_child_delay
name: 收入低推迟生育
priority: 155
condition: ScoreAtMost income 40
condition: WorkerAgeAtLeast int=28
effect: AddChildChance int=-30
effect: AddLifePressure int=10
effect: AddMilestone text="晚育" secondary="经济压力"
effect: AddStoryFragment text="不是不想要孩子，是真的觉得养不起。"
@end

@lifeRule low_income_health_decay
name: 低收入加速身体衰退
priority: 156
condition: ScoreAtMost income 38
condition: RandomChance chance=0.5
effect: AddHealth int=-10
effect: AddFamilyStability int=-10
effect: AddLifePressure int=12
effect: AddMilestone text="看不起病" secondary="健康滑坡"
effect: AddStoryFragment text="小病拖成大病，不是不想治，是治不起。"
@end

@lifeRule performance_volatility
name: 绩效制的收入波动
priority: 160
condition: JobHasTag performance_pay
condition: RandomChance chance=0.45
effect: AddLifeRisk int=12
effect: AddLifePressure int=8
effect: AddFamilyStability int=-8
effect: AddMilestone text="不稳定" secondary="收入起伏"
effect: AddStoryFragment text="好的时候还不错，差的时候全家都在等下个月。"
@end

@lifeRule remote_isolation
name: 远程工作的社交孤岛
priority: 165
condition: JobHasTag remote
condition: RandomChance chance=0.4
effect: AddFamilyStability int=-6
effect: AddParentCare int=-8
effect: AddHeirStat key=communication int=-4
effect: AddStoryFragment text="长期一个人对着屏幕，和外界越来越远。"
@end

@lifeRule appearance_job_trap
name: 靠脸吃饭的保质期
priority: 170
condition: JobHasTag appearance_sensitive
condition: WorkerAgeAtLeast int=35
condition: RandomChance chance=0.5
effect: AddLifePressure int=10
effect: AddProspectScore int=-10
effect: AddMilestone text="过期" secondary="外貌焦虑"
effect: AddStoryFragment text="靠形象吃饭的岗位，年龄一上来就变得焦虑。"
@end

@lifeRule ai_job_obsolescence
name: AI岗位的替代风险
priority: 175
condition: JobHasTag ai
condition: JobHasTag tooling
condition: RandomChance chance=0.35
effect: AddLifeRisk int=14
effect: AddProspectScore int=-12
effect: AddHeirTag key=early_mature
effect: AddMilestone text="替代" secondary="工具迭代"
effect: AddStoryFragment text="工具在进步，但人不一定能跟上，后来也经历过几次被替换的恐慌。"
@end

@lifeRule resume_risk_shadow
name: 简历风险的长期阴影
priority: 178
condition: ResumeRiskAtLeast int=40
condition: RandomChance chance=0.55
effect: AddFamilyReputation int=-12
effect: AddLifeRisk int=14
effect: AddHeirTag key=broken_home
effect: AddHeirStress int=6
effect: AddMilestone text="信用危机" secondary="诚信代价"
effect: AddStoryFragment text="那次包装简历的事后来被翻出来，整个家都蒙了一层阴影。"
@end

@lifeRule resume_risk_caught
name: 简历造假被揭发
priority: 179
condition: ResumeRiskAtLeast int=60
condition: RandomChance chance=0.35
effect: AddFamilyReputation int=-18
effect: AddLifeRisk int=20
effect: AddFamilyStability int=-14
effect: AddHeirTag key=second_gen_migrant
effect: AddMilestone text="穿帮" secondary="信任崩塌"
effect: AddStoryFragment text="造假被揭发后，他不得不频繁换工作，家人也跟着漂泊。"
@end

@lifeRule outdoor_freedom
name: 外勤的自由感
priority: 180
condition: JobHasTag outdoor
condition: RandomChance chance=0.25
effect: AddHeirStat key=resilience int=3
effect: AddLifePressure int=-3
effect: AddStoryFragment text="虽然辛苦，但在外面跑惯了，反而不适应被关在办公室里。"
@end

@lifeRule team_work_family
name: 团队协作的归属感
priority: 185
condition: JobHasTag team_collab
condition: RandomChance chance=0.35
effect: AddFamilyStability int=4
effect: AddChildChance int=3
effect: AddParentCare int=3
effect: AddStoryFragment text="在团队里待久了，回家也学会了配合和让步。"
@end

@lifeRule low_income_no_pension
name: 低薪没有积蓄
priority: 190
condition: ScoreAtMost income 35
effect: AddLifePressure int=14
effect: AddFamilyStability int=-12
effect: AddHeirStress int=8
effect: AddMilestone text="月光" secondary="存不下钱"
effect: AddStoryFragment text="一年到头存不下什么，后来回头看全是空的。"
@end

@lifeRule high_income_expectation
name: 高收入家庭的期待代价
priority: 192
condition: ScoreAtLeast income 78
condition: RandomChance chance=0.5
effect: AddFamilyStability int=6
effect: AddLifePressure int=12
effect: AddHeirStress int=10
effect: AddHeirTag key=parent_expectation
effect: AddMilestone text="补课" secondary="竞争加剧"
effect: AddStoryFragment text="条件变好了，但比较和期待也一起变多。"
@end

