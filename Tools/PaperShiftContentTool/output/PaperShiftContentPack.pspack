# Paper Shift Content Pack v2.1 — Fixed Event Cascade
MergeMode: merge

# ===========================================
# 工作标签 (@workTag)
# ===========================================
# 已有种子: ai, physical, local, remote, office, customer_contact,
#           strict_rules, high_pressure, tooling, fast_change, solo_work, night_shift
# 新增: appearance_sensitive, age_sensitive, height_sensitive,
#        performance_pay, high_communication, outdoor, team_collab, low_threshold

@workTag appearance_sensitive
name: 形象要求
description: 会明显看重外在、表达和第一印象。
requirement: target=FitDimension dimension=Presence int=58 passRecognition=6 failRecognition=-10 failStress=5
eventWeight: event=appearance_question delta=16
eventWeightCondition: kind=RecognitionAtMost int=55
@end

@workTag age_sensitive
name: 年龄敏感
description: 偏好年轻劳动者，年龄大容易吃亏。
requirement: target=RawAttribute key=age op=LessOrEqual int=35 passRecognition=4 failRecognition=-10 failStress=6
eventWeight: event=age_question delta=20
eventWeightCondition: kind=AgeAtLeast int=33
@end

@workTag height_sensitive
name: 身高敏感
description: 对身高有硬性或软性要求，常见于体力、外勤、安保类。
requirement: target=RawAttribute key=height op=GreaterOrEqual int=168 passRecognition=3 failRecognition=-7 failStress=4
eventWeight: event=height_doubt delta=14
eventWeightCondition: kind=Stat key=height op=LessOrEqual int=165
@end

@workTag performance_pay
name: 绩效制
description: 收入和表现直接挂钩，做得好多拿，做不好白干。
requirement: target=FitDimension dimension=Execution int=55 passRecognition=5 failRecognition=-7 failStress=7
eventWeight: event=kpi_review delta=18
eventWeightCondition: kind=RecognitionAtMost int=50
@end

@workTag high_communication
name: 高频沟通
description: 大量会议、协调、汇报，社恐会很痛苦。
requirement: target=FitDimension dimension=Communication int=58 passRecognition=7 failRecognition=-9 failStress=9
eventWeight: event=meeting_mess delta=14
@end

@workTag outdoor
name: 外勤
description: 需要户外跑动，日晒雨淋，体力消耗大。
requirement: target=FitDimension dimension=Physique int=54 passRecognition=3 failRecognition=-6 failStress=6
requirement: target=FitDimension dimension=Resilience int=50 passRecognition=2 failRecognition=-5 failStress=5
@end

@workTag team_collab
name: 团队协作
description: 需要密切配合他人，单打独斗行不通。
requirement: target=FitDimension dimension=Communication int=48 passRecognition=4 failRecognition=-6 failStress=5
@end

@workTag low_threshold
name: 低门槛
description: 入行要求不高，几乎什么人都能试，但天花板也低。
requirement: target=FitDimension dimension=Execution int=35 passRecognition=2 failRecognition=-3 failStress=3
@end

# ===========================================
# 人物标签 (@tag) - 新增
# ===========================================
# 已有15个种子标签。新增更多负面、混合和创建期可选标签。
# 设计原则：正面标签必须带隐性代价，负面标签必须带隐性补偿。

@tag quick_learner
name: 学得快
description: 新东西上手很快，但容易三分钟热度。
rarity: normal
polarity: Positive
effect: passive AddFitScore professionalism 3
effect: passive AddFitScore execution 2
effect: passive PassiveStressPerYear int=1
conditional: phase=Any workTags=fast_change,tooling
conditionalEffect: AddRecognition int=4
conditionalEffect: AddJobWeight key=fast_change int=8
@end

@tag night_owl
name: 夜猫子
description: 习惯了晚睡晚起，夜班反而更适应。
rarity: normal
polarity: Mixed
effect: passive AddFitScore resilience -2
effect: passive AddFitScore maturity -2
conditional: phase=Any workTags=night_shift
conditionalEffect: AddStress int=-6
conditionalEffect: AddRecognition int=3
conditional: phase=Any workTags=office,customer_contact
conditionalEffect: AddRecognition int=-4
conditionalEffect: AddStress int=4
@end

@tag smooth_talker
name: 嘴甜
description: 说话讨喜，面试容易过，但容易说多露馅。
rarity: normal
polarity: Mixed
effect: passive AddFitScore communication 5
effect: passive AddFitScore presence 2
effect: passive PassiveEventWeight resume_audit 6
conditional: phase=Interview workTags=customer_contact,high_communication
conditionalEffect: AddRecognition int=6
conditionalEffect: AddResumeRisk int=4
@end

@tag perfectionist
name: 完美主义
description: 做事追求不出错，但更容易累和崩。
rarity: rare
polarity: Mixed
effect: passive AddFitScore execution 4
effect: passive AddFitScore professionalism 3
effect: passive PassiveStressPerYear int=4
conditional: phase=Any workTags=strict_rules,high_pressure
conditionalEffect: AddRecognition int=5
conditionalEffect: AddStress int=6
@end

@tag lazy_bone
name: 能拖就拖
description: 不到最后不动手，执行力打折。
rarity: normal
polarity: Negative
effect: passive AddFitScore execution -5
effect: passive AddFitScore resilience -2
conditional: phase=Any workTags=strict_rules,performance_pay
conditionalEffect: AddRecognition int=-7
conditionalEffect: AddStress int=7
@end

@tag frugal
name: 精打细算
description: 花钱很谨慎，对成本和收益敏感。
rarity: normal
polarity: Positive
effect: passive AddFitScore professionalism 2
effect: passive AddFitScore execution 2
conditional: phase=Any workTags=performance_pay
conditionalEffect: AddRecognition int=3
conditionalEffect: AddStress int=-2
@end

@tag good_look
name: 长得好看
description: 形象分天然加成，但也容易被看轻能力。
rarity: rare
polarity: Mixed
effect: passive AddFitScore presence 7
effect: passive AddFitScore communication 1
effect: passive AddFitScore credentials -2
conditional: phase=Any workTags=appearance_sensitive,customer_contact
conditionalEffect: AddRecognition int=5
conditionalEffect: AddEventWeight appearance_question 8
conditional: phase=Interview workTags=office
conditionalEffect: AddRecognition int=3
conditionalEffect: AddResumeRisk int=3
@end

@tag tough_body
name: 身体硬
description: 体力好，扛得住累活。
rarity: normal
polarity: Positive
effect: passive AddFitScore physique 5
effect: passive AddFitScore resilience 2
conditional: phase=Any workTags=physical,outdoor
conditionalEffect: AddRecognition int=4
conditionalEffect: AddJobWeight key=physical int=8
@end

@tag thin_skin
name: 脸皮薄
description: 经不起说，被批评容易内耗。
rarity: normal
polarity: Negative
effect: passive AddFitScore resilience -5
effect: passive AddFitScore communication -2
conditional: phase=Any workTags=high_pressure,customer_contact
conditionalEffect: AddStress int=9
conditionalEffect: AddRecognition int=-4
@end

@tag street_smart
name: 路子野
description: 没学历但有办法，本地和人情场景特别有用。
rarity: rare
polarity: Mixed
effect: passive AddFitScore maturity 3
effect: passive AddFitScore communication 2
effect: passive AddFitScore credentials -5
conditional: phase=Any workTags=local,customer_contact
conditionalEffect: AddRecognition int=5
conditionalEffect: AddJobWeight key=local int=10
@end

@tag overconfident
name: 自视甚高
description: 觉得自己比实际强，面试容易翻车。
rarity: normal
polarity: Negative
effect: passive AddFitScore execution -3
effect: passive PassiveEventWeight resume_audit 10
conditional: phase=Interview
conditionalEffect: AddResumeRisk int=10
conditionalEffect: AddRecognition int=-3
@end

@tag family_burden
name: 家里有负担
description: 赚钱压力比别人大，也更拼。
rarity: normal
polarity: Mixed
effect: passive AddFitScore execution 3
effect: passive AddFitScore resilience -4
effect: passive PassiveStressPerYear int=3
@end

@tag small_town
name: 小镇来的人
description: 没什么人脉和资源，但更舍得下功夫。
rarity: normal
polarity: Mixed
effect: passive AddFitScore resilience 2
effect: passive AddFitScore communication -4
effect: passive AddFitScore credentials -3
conditional: phase=Any workTags=local
conditionalEffect: AddRecognition int=-6
conditionalEffect: AddStress int=4
@end

@tag lying_flat
name: 躺平
description: 已经不太想卷了，压力事件后容易获得。
rarity: rare
polarity: Negative
effect: passive AddFitScore execution -5
effect: passive AddFitScore resilience 2
effect: passive PassiveEventWeight stress_breakdown -12
conditional: phase=Any workTags=performance_pay,high_pressure
conditionalEffect: AddRecognition int=-8
conditionalEffect: AddStress int=-6
@end

# 继承专用标签

@tag broken_home
name: 家庭裂痕
description: 父母关系不好，对亲密和稳定更渴望也更焦虑。
rarity: rare
polarity: Mixed
effect: passive AddFitScore maturity 4
