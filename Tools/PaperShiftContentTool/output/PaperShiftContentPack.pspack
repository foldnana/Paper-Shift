conditionalEffect: AddRecognition int=5
@end

# ===========================================
# 事件 (@event) — v2.1 修复级联
# ===========================================
# 核心设计原则：
# - 事件默认一代只触发一次（CooldownYears=0）
# - 每个选项都有代价，不存在免费午餐
# - 简历包装事件必须使用新条件系统
# - 降压力不是免费的
# - 数值从保守开始
# - ** checkpoint 规则：只有含 DirectPass/DirectFail/ReturnToJobSearch
#   的选项才设 checkpoint=true，纯加减效果的选项不设 checkpoint **
# - 不设 checkpoint = 选完直接生效，不再走 checkpoint 流程 = 不会级联触发新事件

# --- 简历包装事件（使用新条件系统）---

@event hidden_age_caught
name: 年龄对不上
body: 面试官发现简历上的年龄信息和实际有出入，追问了细节。
phase: Interview
notice: Modal
baseWeight: 18
condition: kind=ResumeFieldHidden key=age
option: id=admit_age label=承认隐瞒了年龄
optionEffect: AddRecognition int=-8 text="隐瞒年龄让对方更在意诚信问题。"
optionEffect: AddResumeRisk int=8
option: id=deflect_age label=找理由搪塞
optionEffect: AddRecognition int=-5 text="搪塞过去了，但对方明显记了一笔。"
optionEffect: AddResumeRisk int=12
optionEffect: AddStress int=5
@end

@event hidden_education_probed
name: 学历追问
body: 面试官对简历上没写的教育经历很在意，反复追问。
phase: Interview
notice: Modal
baseWeight: 16
condition: kind=ResumeFieldHidden key=education
option: id=reveal label=坦白学历实情
optionEffect: AddRecognition int=-6 text="坦白后对方理解了，但印象分掉了。"
optionEffect: AddResumeRisk int=-8
optionEffect: AddStress int=4
option: id=stonewall label=坚持不透露
optionEffect: AddRecognition int=-10 text="不说话比说错话更让人警觉。"
optionEffect: AddResumeRisk int=10
optionEffect: AddStress int=3
@end

@event exaggerated_salary_check
name: 薪资核实
body: 新公司要求提供前公司的薪资流水，和他简历上夸大的数字差距不小。
phase: Probation
notice: Modal
baseWeight: 16
condition: kind=ResumeFieldExaggerated key=salary
option: id=provide_real label=提供真实流水
optionEffect: AddRecognition int=-10 text="真实数字比简历少了三成，人事脸色不太好看。"
optionEffect: AddResumeRisk int=12
optionEffect: AddStress int=8
option: id=refuse_provide label=说前公司保密不方便提供
optionEffect: AddRecognition int=-6 text="对方没再追问，但薪资谈判的底气也没了。"
optionEffect: AddResumeRisk int=6
optionEffect: AddStress int=4
@end

@event exaggerated_experience_grilled
name: 经历深挖
body: 面试官对他夸大的工作经历特别感兴趣，追问了好几个细节。
phase: Interview
notice: Modal
baseWeight: 18
condition: kind=ResumeFieldExaggerated key=experience
option: id=bluff_through label=硬着头皮编
optionEffect: AddRecognition int=4 text="他编了一段，面试官好像信了。"
optionEffect: AddResumeRisk int=16
optionEffect: AddStress int=6
option: id=backpedal label=主动降低说法
optionEffect: AddRecognition int=-5 text="他承认了实际参与度没那么高，面试官表情复杂。"
optionEffect: AddResumeRisk int=4
optionEffect: AddStress int=3
@end

@event any_hidden_field_suspicion
name: 简历疑点
body: 人事觉得这份简历有些地方不太自然，开始逐项核对。
phase: Interview
notice: Modal
baseWeight: 14
condition: kind=AnyResumeFieldHidden
option: id=come_clean label=主动解释空白处
optionEffect: AddRecognition int=-4 text="他解释了隐藏的原因，对方态度稍微缓和。"
optionEffect: AddResumeRisk int=-5
optionEffect: AddStress int=3
option: id=stay_calm label=装作没问题
optionEffect: AddResumeRisk int=10 text="对方没再追问，但心里的问号更大了。"
optionEffect: AddStress int=4
@end

@event any_exaggerated_field_audit
name: 背景审查
body: 公司的合规部门要对他简历中夸大的部分做例行审查。
phase: Probation
notice: Modal
baseWeight: 15
condition: kind=AnyResumeFieldExaggerated
condition: kind=JobHasTag key=strict_rules
option: id=cooperate label=全力配合审查
optionEffect: AddResumeRisk int=10 text="配合审查反而暴露了更多夸大痕迹。"
optionEffect: AddRecognition int=-8
optionEffect: AddStress int=7
option: id=prepare_story label=提前整理说辞
optionEffect: AddResumeRisk int=6 text="他提前梳理了说辞，但心虚写在了脸上。"
optionEffect: AddStress int=9
optionEffect: AddRecognition int=-4
@end

@event hidden_tag_discovered
name: 标签暴露
body: 同事从别的地方打听到他简历上没写的某个标签，开始议论。
phase: Probation
notice: Modal
baseWeight: 12
condition: kind=AnyResumeTagHidden
option: id=own_it label=坦然承认
optionEffect: AddRecognition int=-3 text="承认了，同事觉得还算坦诚。"
optionEffect: AddResumeRisk int=4
optionEffect: AddStress int=4
option: id=deny_tag label=否认说那是误传
optionEffect: AddRecognition int=-8 text="否认被戳穿了，信任降了一大截。"
optionEffect: AddResumeRisk int=12
optionEffect: AddStress int=6
@end

# --- 面试阶段事件 ---

@event appearance_question
name: 形象质疑
body: 面试官上下打量了一下，表情微妙。
phase: Interview
notice: Modal
baseWeight: 14
condition: kind=JobHasTag key=appearance_sensitive
option: id=dress_up label=刻意收拾一下
optionEffect: AddRecognition int=4 text="他特意整理了仪容，面试官稍微满意了。"
optionEffect: AddStress int=4
option: id=ignore_looks label=不在意形象
optionEffect: AddRecognition int=-9 text="他不修边幅的样子让面试官直接皱眉。"
optionEffect: AddStress int=3
@end

@event age_question
name: 年龄追问
body: 面试官开始追问为什么现在才来应聘这个岗位。
phase: Interview
notice: Modal
baseWeight: 18
condition: kind=AgeAtLeast int=35
option: id=explain label=解释转行原因
optionEffect: AddRecognition int=4 text="解释让对方稍微理解了处境，但没加分。"
optionEffect: AddStress int=5
option: id=avoid label=含糊带过
optionEffect: AddResumeRisk int=14 text="回避让简历风险上升。"
optionEffect: AddRecognition int=-8
@end

@event height_doubt
name: 身高质疑
body: 主管看着他的身高信息，面露犹豫。
phase: Interview
notice: Modal
baseWeight: 12
condition: kind=JobHasTag key=height_sensitive
option: id=prove_strength label=证明体力够用
optionEffect: AddRecognition int=3 text="他展示了力量，主管稍微放心。"
optionEffect: AddStress int=6
option: id=accept_rejection label=承认不太合适
optionEffect: AddRecognition int=-8 text="他坦然承认了，对方反而觉得靠谱。"
optionEffect: AddStress int=-2
@end

@event experience_gap
name: 经历空白
body: 简历上有两段空白期被问到了，面试官想知道那段时间在做什么。
phase: Interview
notice: Modal
baseWeight: 16
option: id=fill_gap label=编一段经历
optionEffect: AddResumeRisk int=14 text="他编了一段经历，但自己也不太确定能不能圆。"
optionEffect: AddRecognition int=2
option: id=be_honest label=实话实说
optionEffect: AddRecognition int=-6 text="他承认了那段低谷，面试官有些犹豫。"
optionEffect: AddStress int=4
@end

@event direct_offer
name: 直接拿offer
body: 面试出奇地顺利，对方当场发了offer。
phase: Interview
notice: Modal
baseWeight: 5
condition: kind=RecognitionAtLeast int=85
option: id=accept label=直接接受 checkpoint=true
optionEffect: DirectPass text="他当场拿到了offer，进入试用期。"
option: id=negotiate label=试着谈条件
optionEffect: AddRecognition int=-4 text="谈条件没成功，差点丢了机会。"
optionEffect: AddStress int=3
@end

@event direct_reject
name: 直接被拒
body: 面试官看了一眼简历就摇头了。
phase: Interview
notice: Modal
baseWeight: 8
condition: kind=RecognitionAtMost int=25
option: id=plead label=争取机会
optionEffect: AddRecognition int=3 text="他争取了一下，对方勉强给了个机会。"
optionEffect: AddStress int=8
option: id=accept_fail label=接受失败 checkpoint=true
optionEffect: DirectFail text="他没有再争取，这次面试结束了。"
optionEffect: AddStress int=-3
@end

# --- 试用期事件 ---

@event kpi_review
name: 绩效考核
body: 本月绩效打分出来了，他需要选择怎么应对。
phase: Probation
notice: Modal
baseWeight: 16
condition: kind=JobHasTag key=performance_pay
option: id=push_harder label=加倍努力
optionEffect: AddRecognition int=6 text="他拼了一把，绩效确实上去了。"
optionEffect: AddStress int=12
option: id=accept_score label=接受当前分数
optionEffect: AddRecognition int=-4 text="分数不高不低，但没什么亮点。"
optionEffect: AddStress int=3
@end

@event meeting_mess
name: 会议翻车
body: 他在一个重要会议上没准备好，被问住了。
phase: Probation
notice: Modal
baseWeight: 14
condition: kind=JobHasTag key=high_communication
option: id=wing_it label=临场发挥
optionEffect: AddRecognition int=-7 text="临场发挥效果不好，漏洞百出。"
optionEffect: AddStress int=9
option: id=admit label=承认没准备好
optionEffect: AddRecognition int=-4 text="坦白承认反而让人觉得靠谱。"
optionEffect: AddStress int=5
@end

@event overtime_fire
name: 周末救火
body: 项目周末出了问题，主管希望他立刻上线处理。
phase: Probation
notice: Modal
baseWeight: 20
cooldown: 2
option: id=work label=接下救火
optionEffect: AddRecognition int=7 text="他扛住了周末救火，认可度上涨。"
optionEffect: AddStress int=14
option: id=refuse label=拒绝加班
optionEffect: AddRecognition int=-8 text="他保住了休息，但主管明显不满。"
optionEffect: AddStress int=-3
@end

@event colleague_conflict
name: 同事排挤
body: 他感觉几个老员工在故意给他穿小鞋。
phase: Probation
notice: Modal
baseWeight: 12
option: id=endure label=忍着不发作
optionEffect: AddRecognition int=1 text="他忍住了，但心里很不好受。"
optionEffect: AddStress int=10
option: id=confront label=找他们谈
optionEffect: AddRecognition int=-5 text="谈了之后关系更僵了。"
optionEffect: AddStress int=6
@end

@event client_complaint
name: 客户投诉
body: 一个客户对他很不满意，写了投诉。
phase: Probation
notice: Modal
baseWeight: 14
condition: kind=JobHasTag key=customer_contact
option: id=apologize_client label=主动道歉补救
optionEffect: AddRecognition int=-5 text="他道了歉，客户态度缓和了一点。"
optionEffect: AddStress int=8
option: id=explain label=解释不是自己的问题
optionEffect: AddRecognition int=-9 text="推卸责任让领导更不满。"
optionEffect: AddStress int=4
@end

@event first_day_mistake
name: 第一天就出错
body: 试用第一天就犯了错，心里很慌。
phase: Probation
notice: Modal
baseWeight: 14
condition: kind=ActionIs text=WorkProbation
condition: kind=CurrentJobMonthsAtMost int=1
option: id=own_up label=主动承认
optionEffect: AddRecognition int=-4 text="承认错误反而让人觉得靠谱，但扣分跑不掉。"
optionEffect: AddStress int=6
option: id=hide_mistake label=试图掩盖
optionEffect: AddResumeRisk int=10 text="掩盖让事情更复杂了。"
optionEffect: AddStress int=8
@end

@event weekend_overtime
name: 周末加班
body: 项目赶进度，主管希望他周末也能来。
phase: Probation
notice: Modal
baseWeight: 18
cooldown: 1
option: id=agree label=同意加班
optionEffect: AddRecognition int=5 text="加班让主管满意了，但身体在抗议。"
optionEffect: AddStress int=10
option: id=decline label=拒绝加班
optionEffect: AddRecognition int=-6 text="他拒绝了，主管不太高兴。"
optionEffect: AddStress int=-2
@end

@event salary_dispute
name: 薪资不符
